  First,
  Second
}

enum UShortEnum: ushort {
  First,
  Second
}
enum UIntEnum: uint {
  First,
  Second
}
enum ULongEnum: ulong {
  First,
  Second
}

table DefaultTable {
  b: bool;
  i8: byte;
  i16: short;
  i32: int;
  i64: long;
