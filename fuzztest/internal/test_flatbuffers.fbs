}

table OptionalTestFbsTable {
  b: bool = null;
  i8: byte = null;
  i16: short = null;
  i32: int = null;
  i64: long = null;
  u8: ubyte = null;
  u16: ushort = null;
  u32: uint = null;
  u64: ulong = null;
  f: float = null;
  d: double = null;
